<!DOCTYPE html>
<html b:version='2' class='v2' expr:dir='data:blog.languageDirection' xmlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr'>

<head>
  <meta content='IE=edge' http-equiv='X-UA-Compatible'/>
  <b:if cond='data:blog.isMobile'>
    <meta content='width=device-width,initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0' name='viewport'/>
  <b:else/>
    <meta content='width=1100' name='viewport'/>
  </b:if>

  <b:include data='blog' name='all-head-content'/>
  <title><data:blog.pageTitle/></title>
  
  <!-- Font Awesome CDN -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>

  <b:skin><![CDATA[
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap');
    @import url('https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;500;600;700&display=swap');

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: 'Inter', sans-serif;
      background: #0B1D51;
      color: #EFEFEF;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      transition: background-color 0.5s ease, color 0.5s ease;
    }

    body.light-mode {
      background: #b0cfff;
      color: #202c4c;
    }

    a {
      color: #00FFE7;
      text-decoration: none;
      font-weight: 700;
      transition: color 0.3s ease;
    }

    body.light-mode a {
      color: #227ea6;
    }

    a:hover,
    a:focus {
      color: #FF0080;
      outline: none;
    }

    body.light-mode a:hover,
    body.light-mode a:focus {
      color: #D6336C;
    }

    header {
      background: #07143f;
      padding: 30px;
      box-shadow: 0 2px 15px rgba(0, 255, 231, 0.15);
      position: sticky;
      top: 0;
      z-index: 1000;
      display: flex;
      justify-content: center;
      position: relative;
      transition: background-color 0.5s ease;
    }

    body.light-mode header {
      background: #a8c3ff;
      box-shadow: 0 2px 15px rgba(34, 126, 166, 0.3);
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 40px;
      font-weight: 700;
      font-size: 1rem;
      user-select: none;
      margin: 0;
      padding: 0;
    }

    nav ul li a {
      padding: 8px 14px;
      border-radius: 12px;
      transition: background-color 0.3s ease;
      display: inline-block;
      position: relative;
      color: inherit;
    }

    nav ul li a:hover,
    nav ul li a:focus {
      background: #00FFE7;
      color: #0B1D51;
      outline: none;
      cursor: pointer;
    }

    body.light-mode nav ul li a:hover,
    body.light-mode nav ul li a:focus {
      background: #227ea6;
      color: #b0cfff;
    }

    nav ul li a.active::after {
      content: '';
      position: absolute;
      bottom: -6px;
      left: 50%;
      transform: translateX(-50%);
      width: 60%;
      height: 3px;
      border-radius: 2px;
      background-color: #FF0080;
    }

    body.light-mode nav ul li a.active::after {
      background-color: #D6336C;
    }

    #darkModeToggle {
      position: fixed;
      top: 20px;
      right: 20px;
      background: transparent;
      border: 2px solid #00FFE7;
      border-radius: 20px;
      color: #00FFE7;
      cursor: pointer;
      padding: 6px 14px;
      font-weight: 700;
      font-size: 0.9rem;
      z-index: 1051;
      transition: all 0.3s ease;
      user-select: none;
    }

    #darkModeToggle:hover,
    #darkModeToggle:focus {
      background: #00FFE7;
      color: #0B1D51;
      outline: none;
    }

    body.light-mode #darkModeToggle {
      border-color: #227ea6;
      color: #227ea6;
    }

    body.light-mode #darkModeToggle:hover,
    body.light-mode #darkModeToggle:focus {
      background: #227ea6;
      color: #b0cfff;
    }

    section.hero {
      background: #082354;
      color: #00FFE7;
      text-align: center;
      padding: 120px 20px 140px;
      border-radius: 0 0 48px 48px;
      box-shadow: 0 12px 45px rgba(0, 255, 231, 0.5);
      user-select: none;
      opacity: 0;
      transform: translateY(30px);
      animation: fadeInUp 1s forwards 0.2s;
      transition: background-color 0.5s ease, color 0.5s ease;
    }

    body.light-mode section.hero {
      background: #95bbff;
      color: #202c4c;
      box-shadow: 0 12px 45px rgba(34, 126, 166, 0.4);
    }

    section.hero h1 {
      font-size: 3.8rem;
      font-weight: 700;
      margin-bottom: 16px;
      letter-spacing: 0.08em;
    }

    section.hero p {
      font-size: 1.3rem;
      max-width: 650px;
      margin: 0 auto 50px;
      color: #A0A0A0;
      font-weight: 400;
      user-select: text;
    }

    body.light-mode section.hero p {
      color: #2d3c6a;
    }

    section.hero a.button {
      background: #00FFE7;
      color: #0B1D51;
      padding: 16px 56px;
      border-radius: 50px;
      font-weight: 700;
      font-size: 1.15rem;
      box-shadow: 0 7px 25px rgba(0, 255, 231, 0.5);
      text-transform: uppercase;
      cursor: pointer;
      user-select: none;
      text-decoration: none;
      transition: background-color 0.3s ease, box-shadow 0.3s ease;
      display: inline-block;
    }

    section.hero a.button:hover,
    section.hero a.button:focus {
      background: #FF0080;
      color: #FFF;
      box-shadow: 0 10px 35px rgba(255, 0, 128, 0.7);
      outline: none;
    }

    body.light-mode section.hero a.button {
      background: #227ea6;
      color: #b0cfff;
      box-shadow: none;
    }

    body.light-mode section.hero a.button:hover,
    body.light-mode section.hero a.button:focus {
      background: #d6426c;
      color: white;
      box-shadow: 0 8px 30px rgba(214, 66, 108, 0.75);
    }

    section#about {
      max-width: 720px;
      margin: 60px auto 88px;
      padding: 40px 32px;
      background: #142c69;
      border-radius: 48px;
      box-shadow: 0 8px 48px rgba(0, 255, 231, 0.3);
      user-select: none;
      transition: background-color 0.5s ease, color 0.5s ease;
    }

    body.light-mode section#about {
      background: #b0cfff !important;
      color: #202c4c !important;
      box-shadow: 0 8px 48px rgba(34, 126, 166, 0.3) !important;
    }

    body.light-mode section#about h2 {
      color: #227ea6 !important;
    }

    body.light-mode section#about p {
      color: #2d3c6a !important;
    }

    .skill-bar-container {
      max-width: 560px;
      margin: 0 auto;
    }

    .skill-bar-label {
      font-weight: 600;
      margin-bottom: 8px;
      font-size: 1rem;
      color: #A0A0A0;
      transition: color 0.5s ease;
    }

    body.light-mode .skill-bar-label {
      color: #2d3c6a;
    }

    .skill-bar {
      background-color: #0B1D51;
      border-radius: 30px;
      overflow: hidden;
      height: 14px;
      box-shadow: inset 0 1px 3px rgba(255, 0, 128, 0.5);
      margin-bottom: 28px;
      transition: background-color 0.5s ease;
    }

    body.light-mode .skill-bar {
      background-color: #d4e2ff;
      box-shadow: inset 0 1px 3px rgba(214, 66, 108, 0.3);
    }

    .skill-bar-fill {
      height: 100%;
      border-radius: 30px;
      background: linear-gradient(90deg, #00FFE7, #FF0080);
      width: 0;
      transition: width 2s ease;
    }

    main {
      max-width: 1040px;
      margin: 0 auto;
      padding: 0 20px 0 20px;
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 64px;
      align-items: start;
      user-select: none;
      transition: background-color 0.5s ease, color 0.5s ease;
    }

    aside.profile {
      background: #07143f;
      padding: 40px 30px;
      border-radius: 64px;
      box-shadow: 0 16px 56px rgba(0, 255, 231, 0.35);
      text-align: center;
      position: sticky;
      top: 120px;
      opacity: 0;
      transform: translateY(30px);
      animation: fadeInUp 1s forwards 0.4s;
      transition: background-color 0.5s ease, color 0.5s ease;
    }

    body.light-mode aside.profile {
      background: #b0cfff;
      color: #202c4c;
      box-shadow: 0 14px 42px rgba(34, 126, 166, 0.25);
    }

    aside.profile img {
      width: 180px;
      height: 180px;
      border-radius: 50%;
      border: 6px solid #00FFE7;
      margin-bottom: 28px;
      object-fit: cover;
      box-shadow: 0 14px 36px rgba(0, 255, 231, 0.75);
      transition: transform 0.4s ease;
    }

    aside.profile img:hover {
      transform: scale(1.05);
    }

    aside.profile h2 {
      font-weight: 700;
      font-size: 2rem;
      margin-bottom: 12px;
      color: #00FFE7;
      transition: color 0.5s ease;
    }

    body.light-mode aside.profile h2 {
      color: #227ea6;
    }

    aside.profile p {
      color: #A0A0A0;
      font-size: 1.1rem;
      line-height: 1.6;
      transition: color 0.5s ease;
    }

    body.light-mode aside.profile p {
      color: #405258;
    }

    section.portfolio {
      background: #142c69;
      padding: 48px 40px 48px;
      border-radius: 64px;
      box-shadow: 0 18px 69px rgba(0, 255, 231, 0.38);
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 42px;
      opacity: 0;
      transform: translateY(30px);
      animation: fadeInUp 1s forwards 0.6s;
      transition: background-color 0.5s ease, color 0.5s ease;
    }

    body.light-mode section.portfolio {
      background: #95bbff;
      color: #202c4c;
      box-shadow: 0 18px 62px rgba(34, 126, 166, 0.2);
    }

    section.portfolio h2 {
      grid-column: 1 / -1;
      color: #00FFE7;
      font-size: 2.75rem;
      font-weight: 700;
      margin-bottom: 44px;
      user-select: none;
      text-align: center;
      letter-spacing: 0.05em;
      position: relative;
    }

    body.light-mode section.portfolio h2 {
      color: #227ea6;
    }

    section.portfolio h2::after {
      content: '';
      display: block;
      width: 80px;
      height: 3px;
      background-color: #FF0080;
      margin: 8px auto 0 auto;
      border-radius: 2px;
    }

    section.portfolio-item {
      background: #0b1e52;
      border-radius: 40px;
      box-shadow: 0 14px 48px rgba(0, 255, 231, 0.27);
      overflow: hidden;
      text-align: center;
      transition: transform 0.3s ease, box-shadow 0.3s ease,
        background-color 0.5s ease, color 0.5s ease;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      user-select: text;
      position: relative;
      will-change: transform;
    }

    body.light-mode section.portfolio-item {
      background: #ecf5f8;
      color: #0B1D51;
      box-shadow: 0 14px 24px rgba(34, 184, 207, 0.15);
    }

    section.portfolio-item:hover,
    section.portfolio-item:focus-within {
      transform: translateY(-14px) scale(1.04);
      box-shadow: 0 30px 66px rgba(255, 0, 128, 0.64);
      outline: none;
      z-index: 10;
    }

    section.portfolio-item img {
      border-top-left-radius: 40px;
      border-top-right-radius: 40px;
      height: 190px;
      width: 100%;
      object-fit: cover;
      filter: brightness(0.9);
      transition: filter 0.35s ease;
    }

    section.portfolio-item:hover img,
    section.portfolio-item:focus-within img {
      filter: brightness(0.7);
    }

    section.portfolio-item h3 {
      margin: 22px 24px 12px;
      font-weight: 700;
      font-size: 1.5rem;
      color: #FF0080;
      user-select: text;
      transition: color 0.5s ease;
    }

    body.light-mode section.portfolio-item h3 {
      color: #D6336C;
    }

    section.portfolio-item p {
      margin: 0 24px 32px;
      font-size: 1.1rem;
      color: #B0B5BA;
      flex-grow: 1;
      user-select: text;
      line-height: 1.5;
      transition: color 0.5s ease;
    }

    body.light-mode section.portfolio-item p {
      color: #444444;
    }

    section.portfolio-item a {
      margin: 0 24px 34px;
      padding: 14px 36px;
      background: #FF0080;
      color: white;
      border-radius: 32px;
      font-weight: 600;
      font-size: 1rem;
      text-transform: uppercase;
      user-select: none;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      text-align: center;
      transition: background-color 0.3s ease;
      box-shadow: 0 6px 20px rgba(255, 0, 128, 0.35);
    }

    section.portfolio-item a:hover,
    section.portfolio-item a:focus {
      background-color: #00FFE7;
      color: #0B1D51;
      outline: none;
      box-shadow: 0 8px 26px rgba(0, 255, 231, 0.6);
    }

    section.contact {
      background: #0B1D51;
      border-radius: 72px;
      padding: 96px 48px;
      max-width: 720px;
      margin: 88px auto 72px;
      text-align: center;
      color: #EFEFEF;
      user-select: none;
      box-shadow: 0 22px 90px rgba(0, 255, 231, 0.62);
      opacity: 0;
      transform: translateY(30px);
      animation: fadeInUp 1s forwards 0.8s;
      transition: background-color 0.5s ease, color 0.5s ease;
    }

    body.light-mode section.contact {
      background: #95bbff;
      color: #202c4c;
      box-shadow: 0 18px 60px rgba(34, 126, 166, 0.3);
    }

    section.contact h2 {
      font-size: 3.2rem;
      font-weight: 700;
      margin-bottom: 48px;
      letter-spacing: 0.08em;
    }

    section.contact p {
      font-size: 1.4rem;
      line-height: 1.7;
      margin-bottom: 56px;
    }

    /* Social icons container */
    .social-icons {
      margin: 0 auto 40px;
      display: flex;
      justify-content: center;
      gap: 24px;
      max-width: 440px;
    }

    .social-icons a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      background: #0B1D51;
      border-radius: 50%;
      color: #00FFE7;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    body.light-mode .social-icons a {
      background: #b0cfff;
      color: #202c4c;
    }

    .social-icons a:hover,
    .social-icons a:focus {
      background-color: #FF0080;
      color: white;
      outline: none;
    }

    body.light-mode .social-icons a:hover,
    body.light-mode .social-icons a:focus {
      background-color: #d6426c;
      color: white;
    }

    .social-icons svg {
      width: 20px;
      height: 20px;
    }

    section.contact a.button-contact {
      display: inline-block;
      padding: 26px 80px;
      background: #00FFE7;
      color: #0B1D51;
      font-weight: 700;
      font-size: 1.3rem;
      border-radius: 80px;
      letter-spacing: 0.1em;
      cursor: pointer;
      user-select: none;
      text-decoration: none;
      text-transform: uppercase;
      transition: background-color 0.3s ease, box-shadow 0.3s ease;
      box-shadow: 0 14px 52px rgba(0, 255, 231, 0.8);
    }

    section.contact a.button-contact:hover,
    section.contact a.button-contact:focus {
      background-color: #FF0080;
      box-shadow: 0 18px 72px rgba(255, 0, 128, 0.9);
      outline: none;
    }

    footer {
      color: #9FA7B8;
      font-size: 0.95rem;
      font-weight: 600;
      text-align: center;
      padding: 48px 16px 28px;
      letter-spacing: 0.04em;
      user-select: none;
    }

    footer a {
      color: #FF0080;
      font-weight: 700;
      text-decoration: underline;
      transition: color 0.3s ease;
    }

    footer a:hover,
    footer a:focus {
      color: #00FFE7;
      outline: none;
    }

    #backToTop {
      display: none;
      position: fixed;
      bottom: 30px;
      right: 30px;
      z-index: 1050;
      background-color: #00FFE7;
      border: none;
      border-radius: 50%;
      width: 52px;
      height: 52px;
      cursor: pointer;
      box-shadow: 0 6px 20px rgba(0, 255, 231, 0.7);
      transition: background-color 0.3s ease, transform 0.3s ease;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    #backToTop svg {
      fill: #0B1D51;
    }

    #backToTop:hover,
    #backToTop:focus {
      background-color: #FF0080;
      color: white;
      outline: none;
      transform: scale(1.1);
    }

    a:focus,
    button:focus {
      outline: 3px solid #FF0080;
      outline-offset: 3px;
    }

    @keyframes fadeInUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 900px) {
      main {
        grid-template-columns: 1fr;
        gap: 70px;
      }

      aside.profile {
        position: static;
        max-width: 100%;
        margin: 0 auto;
        padding: 48px 32px;
        border-radius: 48px;
        box-shadow: 0 20px 65px rgba(0, 255, 231, 0.3);
        top: auto;
      }

      section.portfolio {
        padding: 54px 32px 48px;
        border-radius: 48px;
        box-shadow: 0 18px 60px rgba(0, 255, 231, 0.25);
      }

      section.contact {
        margin: 60px 32px 40px;
        padding: 84px 32px;
      }

      #darkModeToggle {
        position: fixed;
        top: 20px;
        right: 15px;
        padding: 5px 12px;
        font-size: 0.85rem;
    /* Chapter sections with collapsible functionality */
    .chapters-section {
      max-width: 720px;
      margin: 60px auto 88px;
      padding: 48px 32px;
      background: #142c69;
      border-radius: 48px;
      box-shadow: 0 8px 48px rgba(0,255,231,0.3);
      user-select: none;
    }

    body.light-mode .chapters-section {
      background: #95bbff;
    }

    .chapters-section h2 {
      color: #00FFE7;
      margin-bottom: 30px;
      text-align: center;
      font-size: 2.5rem;
      font-weight: 700;
    }

    body.light-mode .chapters-section h2 {
      color: #227ea6;
    }

    .chapter-item {
      margin-bottom: 20px;
      border: 1px solid #2a4a8a;
      border-radius: 12px;
      overflow: hidden;
      background: #0f1f54;
    }

    body.light-mode .chapter-item {
      border-color: #7ca8d9;
      background: #a8c8ff;
    }

    .chapter-item summary {
      padding: 20px 24px;
      cursor: pointer;
      font-size: 1.2rem;
      font-weight: 600;
      color: #EFEFEF;
      background: #1a3a75;
      border: none;
      outline: none;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: background-color 0.3s ease;
      font-family: 'Hind Siliguri', 'Inter', sans-serif;
    }

    body.light-mode .chapter-item summary {
      color: #202c4c;
      background: #b8d4ff;
    }

    .chapter-item summary:hover {
      background: #2550a0;
    }

    body.light-mode .chapter-item summary:hover {
      background: #9bc4ff;
    }

    /* Font Awesome chevron icon - replaces problematic Unicode arrow */
    .chapter-item summary::after {
      content: '\f078'; /* Font Awesome chevron-down */
      font-family: 'Font Awesome 6 Free';
      font-weight: 900;
      font-size: 12px;
      transition: transform 0.3s ease;
      margin-left: auto;
    }

    .chapter-item[open] summary::after {
      transform: rotate(180deg);
    }

    .chapter-content {
      padding: 24px;
      background: #0B1D51;
      color: #B0B5BA;
      line-height: 1.6;
      font-size: 1rem;
    }

    body.light-mode .chapter-content {
      background: #d1e5ff;
      color: #3a4f6f;
    }

    .chapter-content p {
      margin: 0 0 16px 0;
    }

    .chapter-content p:last-child {
      margin-bottom: 0;
    }

    @media (max-width: 768px) {
      .chapters-section {
        margin: 40px 16px 60px;
        padding: 32px 20px;
        border-radius: 32px;
      }

      .chapter-item summary {
        padding: 16px 20px;
        font-size: 1.1rem;
      }

      .chapter-content {
        padding: 20px;
      }
    }
</head>

<body>
  <header>
    <nav aria-label='Primary Navigation' role='navigation'>
      <ul>
        <li><a class='active' href='#hero'>Home</a></li>
        <li><a href='#about'>About</a></li>
        <li><a href='#chapters'>Chapters</a></li>
        <li><a href='#portfolio'>Portfolio</a></li>
        <li><a href='#contact'>Contact</a></li>
      </ul>
      <button aria-label='Toggle Dark Mode' id='darkModeToggle' title='Toggle Dark Mode' type='button'>Light Mode</button>
    </nav>
  </header>

  <section aria-label='Introductory Section' class='hero' id='hero' tabindex='0'>
    <h1>Elevated Online Presence</h1>
    <p>Crafting modern websites with clean, engaging designs that connect you to your audience.</p>
    <a class='button' href='#contact' role='button' tabindex='0'>Work With Me</a>
  </section>

  <section aria-label='About Section' id='about' style='max-width: 720px; margin: 60px auto 88px; padding: 40px 32px; background: #142c69; border-radius: 48px; box-shadow: 0 8px 48px rgba(0,255,231,0.3); user-select:none;' tabindex='0'>
    <h2 style='color:#00FFE7; margin-bottom: 30px; text-align: center;'>About Me</h2>
    <p style='font-size:1.15rem; line-height:1.6; color:#B0B5BA; margin-bottom: 48px;'>
